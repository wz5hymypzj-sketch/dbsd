    if(monitorGain && !micPaused) monitorGain.gain.value = 25.0;
  } else {
    $('btnPassThrough').textContent = 'PASS: OFF'; $('btnPassThrough').style.background = '#ffffff'; $('btnPassThrough').style.color = '#000000'; $('btnPassThrough').style.borderColor = '#000000';
    if(monitorGain) monitorGain.gain.value = 0;
  }
};

$('btnTunerToggle').onclick = () => {
  tunerActive = !tunerActive;
  const btn = $('btnTunerToggle');
  const out = $('tunerReadout');
  if(tunerActive) {
    btn.textContent = 'TUNER: ON'; btn.style.background = '#000'; btn.style.color = '#fff';
    out.className = 'guide-result guide-res-pass';
    smoothedPitch = -1; 
    tunerDataArray = new Float32Array(analyserTuner.fftSize); runTuner();
  } else {
    btn.textContent = 'TUNER: OFF'; btn.style.background = '#fff'; btn.style.color = '#000';
    out.className = 'guide-result guide-res-wait'; out.innerHTML = '--- Hz';
  }
}

function updateRollBounds() { while (lowerMidi < rollBaseMidi) rollBaseMidi -= 12; while (lowerMidi >= rollBaseMidi + 12) rollBaseMidi += 12; }
function enforceReblitzLimits() { const ivDef = IV[curIv]; if (lowerMidi < ivDef.min) lowerMidi = ivDef.min; if (lowerMidi > ivDef.max) lowerMidi = ivDef.max; updateRollBounds(); }

function resetCapture() {
  captureState = 'IDLE'; capturedBeats = []; lockedAverage = null; 
  if (!micPaused) { $('captureStateLbl').textContent = 'READY'; $('captureStateLbl').style.color = '#666'; }
  avgEl.textContent = '—';
}

function buildPianoRoll() {
  const roll = $('pianoRoll'); const ivDef = IV[curIv]; roll.innerHTML = '';
  for (let m = rollBaseMidi; m < rollBaseMidi + 12; m++) {
    const key = document.createElement('div'); const isSharp = IS_SHARP.has(m % 12);
    key.className = 'pk' + (isSharp ? ' sh' : ''); key.dataset.midi = m;
    if (m >= ivDef.min && m <= ivDef.max) {
      key.textContent = noteName(m);
      key.addEventListener('click', () => { lowerMidi = m; currentChunkSize = (lowerMidi > 60) ? 256 : 1024; resetCapture(); refreshUI(); });
    } else { key.classList.add('disabled'); if (!isSharp) key.textContent = noteName(m); }
    roll.appendChild(key);
  }
  refreshUI();
}

function refreshUI() {
  const cfg = getConfig(lowerMidi, curIv);
  document.querySelectorAll('.pk').forEach(k => {
    let m = parseInt(k.dataset.midi);
    k.classList.toggle('on', m === cfg.lowerMidi);
    k.classList.toggle('on-top', m === cfg.upperMidi);
  });
  $('lblInterval').textContent = `${noteName(cfg.lowerMidi)} - ${noteName(cfg.upperMidi)}`;
  $('coincidentPartial').textContent = `${cfg.iv.lp}x / ${cfg.iv.up}x ≈ ${cfg.center.toFixed(1)} Hz`;
  $('lblTarget').textContent = `~${cfg.theoBeat.toFixed(2)}`;
  retuneFilters(cfg);
}

$('octDown').addEventListener('click', () => { if (rollBaseMidi > 12) { rollBaseMidi -= 12; buildPianoRoll(); } });
$('octUp').addEventListener('click', () => { if (rollBaseMidi < 108) { rollBaseMidi += 12; buildPianoRoll(); } });
$('btnBigDown').addEventListener('click', () => { if (!isRunning || lowerMidi <= IV[curIv].min) return; lowerMidi--; updateRollBounds(); currentChunkSize = (lowerMidi > 60) ? 256 : 1024; resetCapture(); buildPianoRoll(); });
$('btnBigUp').addEventListener('click', () => { if (!isRunning || lowerMidi >= IV[curIv].max) return; lowerMidi++; updateRollBounds(); currentChunkSize = (lowerMidi > 60) ? 256 : 1024; resetCapture(); buildPianoRoll(); });
window.addEventListener('keydown', (e) => { if (!isRunning) return; if (e.key === 'ArrowRight') { e.preventDefault(); $('btnBigUp').click(); } else if (e.key === 'ArrowLeft') { e.preventDefault(); $('btnBigDown').click(); } });

function finalizeLog() {
  if (lockedAverage === null) return;
  const cfg = getConfig(lowerMidi, curIv);
  let entry = loggedIntervals[curIv].find(x => x.midi === lowerMidi);
  if (!entry) { entry = { midi: lowerMidi, noteName: noteName(lowerMidi), strikes: [], measured: 0, target: cfg.theoBeat }; loggedIntervals[curIv].push(entry); }
  entry.strikes.push(lockedAverage);
  let sortedStrikes = [...entry.strikes].sort((a,b) => a-b);
  entry.measured = sortedStrikes[Math.floor(sortedStrikes.length/2)];
  savePersistence(); renderLogTable(); analyzeTemperament(); updateGuide(); updateDynRes();
}

window.deleteEntry = function(iv, midi) { 
  loggedIntervals[iv] = loggedIntervals[iv].filter(e => e.midi !== midi); 
  savePersistence(); renderLogTable(); analyzeTemperament(); updateGuide(); updateDynRes();
};

function renderLogTable() {
  const tb = $('logBody'); tb.innerHTML = ''; let entries = loggedIntervals[curIv] || [];
  if (entries.length > 0) {
    entries.sort((a, b) => a.midi - b.midi);
    for (let i = 0; i < entries.length; i++) {
      if (i > 0) {
        const pct = ((entries[i].measured - entries[i-1].measured) / entries[i-1].measured) * 100;
        entries[i].pctStr = (pct > 0 ? '+' : '') + pct.toFixed(1) + '%'; entries[i].isWrong = (pct <= 0);
      } else { entries[i].pctStr = '-'; entries[i].isWrong = false; }
    }
    tb.innerHTML += `<tr style="background:#f4f4f4; border-bottom:1px solid #000;"><td colspan="6" style="text-align:center; font-weight:800; font-size:0.8rem; padding:4px;">${curIv} PROGRESSION</td></tr>`;
    for (let i = entries.length - 1; i >= 0; i--) {
      const c = entries[i];
      const rowStyle = c.isWrong ? 'background-color: #ffeaea; color: #d00000; font-weight: 700;' : '';
      const strikeCountStr = c.strikes.length > 1 ? ` <span style="font-size:0.6rem; color:#666;">(${c.strikes.length}x)</span>` : '';
      tb.innerHTML += `<tr style="${rowStyle}"><td><b>${curIv}</b></td><td style="font-weight:800;">${c.noteName}</td><td style="font-weight:700; font-size:0.85rem;">${c.measured.toFixed(2)}${strikeCountStr}</td><td style="font-weight:700;">${c.pctStr}</td><td class="w">~${c.target.toFixed(2)}</td><td><button class="btn-del" onclick="deleteEntry('${curIv}', ${c.midi})">X</button></td></tr>`;
    }
  } else { tb.innerHTML = '<tr><td colspan="6" style="text-align:center; padding:15px; color:#666;">Logs automatically upon solid capture</td></tr>'; }
}

function analyzeTemperament() {
  let nudges = {}; const getOrInit = (m) => { if(!nudges[m]) nudges[m] = { note: noteName(m), up: [], down: [] }; return nudges[m]; };
  let allLogs = []; Object.keys(loggedIntervals).forEach(ivKey => { loggedIntervals[ivKey].forEach(entry => { allLogs.push({ ivKey, ...entry }); }); });
  allLogs.forEach(log => {
      let ivDef = IV[log.ivKey]; let m1 = log.midi; let m2 = log.midi + ivDef.sem;
      let margin = Math.max(0.2, log.target * 0.05); let diff = log.measured - log.target;
      if (Math.abs(diff) <= margin) return; 
      let isFast = diff > 0; let reason = `${log.ivKey} ${noteName(m1)} is ${isFast ? 'fast' : 'slow'}`;
      let isWideInterval = ['M3','M6','M10','M17','P4'].includes(log.ivKey);
      let needsNarrowing = (isWideInterval && isFast) || (!isWideInterval && !isFast);
      let needsWidening = (isWideInterval && !isFast) || (!isWideInterval && isFast);
      if (needsNarrowing) { getOrInit(m1).up.push(reason); getOrInit(m2).down.push(reason); } 
      else if (needsWidening) { getOrInit(m1).down.push(reason); getOrInit(m2).up.push(reason); }
  });
  let suggestions = [];
  Object.keys(nudges).forEach(mStr => {
      let m = parseInt(mStr); let n = nudges[m]; let note = n.note;
      if (n.up.length >= 2 && n.down.length === 0) suggestions.push(`<b style="color:#d00000;">${note} &uarr;</b> - ${n.up.join(' - ')}`);
      else if (n.down.length >= 2 && n.up.length === 0) suggestions.push(`<b style="color:#000;">${note} &darr;</b> - ${n.down.join(' - ')}`);
  });
  let box = $('analysisBox');
  if (suggestions.length > 0) { box.style.display = 'block'; box.innerHTML = `<div style="text-align:left; font-size:0.75rem; font-weight: 500; line-height:1.4;">${suggestions.join('<br>')}</div>`; } 
  else { box.style.display = 'none'; box.innerHTML = ''; }
}

function getLogVal(iv, noteNameStr) { let e = loggedIntervals[iv].find(x => x.noteName === noteNameStr); return e ? e.measured : null; }

function updateActionButtons() {
  document.querySelectorAll('.action-btn').forEach(btn => {
    let iv = btn.dataset.iv;
    let midiStr = btn.dataset.midi;
    if(!iv || !midiStr) return; // Skip if it doesn't have tracking data
    
    let midi = parseInt(midiStr);
    let label = btn.dataset.label;
    let val = getLogVal(iv, noteName(midi));
    
    if (val !== null) {
      btn.innerHTML = `${label}<br><span style="font-size:0.95em; font-weight:900;">[${val.toFixed(2)}]</span>`;
      btn.classList.add('logged');
    } else {
      btn.innerHTML = label;
      btn.classList.remove('logged');
    }
  });
}

function updateGuide() { checkStep2(); checkStep3(); checkStep4(); checkStep5(); checkStep6(); checkStep7(); checkStep8(); checkStep9(); checkStep10(); updateActionButtons(); }

function checkStep2() {
  let m3 = getLogVal('M3', 'F3'), m10 = getLogVal('M10', 'F3'); let res = $('guideRes2');
  if(!m3 || !m10) { res.className = 'guide-result guide-res-wait'; res.innerHTML = "Awaiting logs..."; return; }
  let diff = m10 - m3; let html = `M3: ${m3.toFixed(2)} | M10: ${m10.toFixed(2)}<br>`;
  if(diff >= -0.1 && diff <= 0.6) { res.className = 'guide-result guide-res-pass'; html += `✔ Solid 4:2 Octave!`; }
  else if (diff > 0.6) { res.className = 'guide-result guide-res-warn'; html += `Octave too wide. SHARPEN A3.`; }
  else { res.className = 'guide-result guide-res-warn'; html += `Octave too narrow. FLATTEN A3.`; }
  res.innerHTML = html;
}

function checkStep3() {
  let m3 = getLogVal('M3', 'F3'); let res = $('guideRes3');
  if(!m3) { res.className = 'guide-result guide-res-wait'; res.innerHTML = "Awaiting logs..."; return; }
  
  if (m3 >= 6.7 && m3 <= 7.2) {
    res.className = 'guide-result guide-res-pass'; res.innerHTML = `F3-A3(M3): ${m3.toFixed(2)} bps<br>✔ Solid anchor.`;
  } else if (m3 < 6.7) {
    res.className = 'guide-result guide-res-warn'; res.innerHTML = `F3-A3(M3): ${m3.toFixed(2)} bps<br>Too slow. FLATTEN F3.`;
  } else {
    res.className = 'guide-result guide-res-warn'; res.innerHTML = `F3-A3(M3): ${m3.toFixed(2)} bps<br>Too fast. SHARPEN F3.`;
  }
}

function checkStep4() {
  let m3 = getLogVal('M3', 'C#3'), m10 = getLogVal('M10', 'C#3'); let res = $('guideRes4');
  if(!m3 || !m10) { res.className = 'guide-result guide-res-wait'; res.innerHTML = "Awaiting logs..."; return; }
  let diff = m10 - m3; let html = `M3: ${m3.toFixed(2)} | M10: ${m10.toFixed(2)}<br>`;
  if(diff >= -0.1 && diff <= 0.6) { res.className = 'guide-result guide-res-pass'; html += `✔ Solid 4:2 Octave!`; }
  else if (diff > 0.6) { res.className = 'guide-result guide-res-warn'; html += `Octave too wide. FLATTEN F4.`; }
  else { res.className = 'guide-result guide-res-warn'; html += `Octave too narrow. SHARPEN F4.`; }
  res.innerHTML = html;
}

function checkStep5() {
  let f3 = getLogVal('M3', 'F3'), a3 = getLogVal('M3', 'A3'), c4 = getLogVal('M3', 'C#4'); let res = $('guideRes5');
  if(!f3 || !a3 || !c4) { res.className = 'guide-result guide-res-wait'; res.innerHTML = "Awaiting logs..."; return; }
  let r1 = ((a3 - f3) / f3) * 100, r2 = ((c4 - a3) / a3) * 100;
  let html = `F3&rarr;A3: +${r1.toFixed(0)}% | A3&rarr;C#4: +${r2.toFixed(0)}%<br>`;
  let target = 26, tol = 6; let r1Good = Math.abs(r1 - target) <= tol, r2Good = Math.abs(r2 - target) <= tol;
  if (r1Good && r2Good) { res.className = 'guide-result guide-res-pass'; html += `✔ PROPORTIONAL SPACING!`; }
  else if (r1 > target + tol && r2 < target - tol) { res.className = 'guide-result guide-res-warn'; html += `SHARPEN A3 or FLATTEN C#4`; }
  else if (r1 < target - tol && r2 > target + tol) { res.className = 'guide-result guide-res-warn'; html += `FLATTEN A3 or SHARPEN C#4`; }
  else if (r1 < target - tol && r2 < target - tol) { res.className = 'guide-result guide-res-warn'; html += `Both jumps too small. FLATTEN F3 (Step 3).`; }
  else if (r1 > target + tol && r2 > target + tol) { res.className = 'guide-result guide-res-warn'; html += `Both jumps too large. SHARPEN F3 (Step 3).`; }
  else { res.className = 'guide-result guide-res-warn'; html += `Spacing uneven. Tweak A3 or C#4.`; }
  res.innerHTML = html;
}

function checkStep6() {
  let p5 = getLogVal('P5', 'F#3'), p4_f = getLogVal('P4', 'F3'), p4_a = getLogVal('P4', 'A3'), m3f = getLogVal('M3', 'F#3'), m3a = getLogVal('M3', 'A#3'); 
  let res = $('guideRes6');
