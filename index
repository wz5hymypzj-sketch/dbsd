<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>DAN'S BEAT SPEED DETECTOR - V20</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background: #ffffff; color: #000000; display: flex; flex-direction: column;
    height: 100dvh; overflow: hidden; padding: 8px; padding-bottom: 2px; 
    max-width: 480px; margin: 0 auto; position: relative;
  }

  #startOverlay {
    position: fixed; inset: 0; background: #ffffff; z-index: 9999; display: flex;
    flex-direction: column; align-items: center; justify-content: center; padding: 20px; text-align: center;
  }
  #startOverlay h1 {
    font-size: clamp(2rem, 10vw, 3.8rem); margin-bottom: 40px; color: #ff0000; font-weight: 900; 
    font-style: italic; text-align: center; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1;
    text-shadow: 4px 4px 0 #000, -4px -4px 0 #000, 4px -4px 0 #000, -4px 4px 0 #000,
                 4px 0px 0 #000, -4px 0px 0 #000, 0px 4px 0 #000, 0px -4px 0 #000;
  }
  #bigStartBtn {
    background: transparent; color: #ffffff; font-size: 2.2rem; font-weight: 900; font-style: italic;
    padding: 12px 36px; border: 4px solid #000000; border-radius: 8px; cursor: pointer; text-transform: uppercase;
    transition: transform 0.1s; box-shadow: 0 6px 0px #000;
    text-shadow: 3px 3px 0 #000, -3px -3px 0 #000, 3px -3px 0 #000, -3px 3px 0 #000,
                 3px 0px 0 #000, -3px 0px 0 #000, 0px 3px 0 #000, 0px -3px 0 #000;
  }
  #bigStartBtn:active { transform: translateY(4px); box-shadow: 0 2px 0px #000; }

  .header { display: flex; flex-direction: column; justify-content: center; align-items: center; margin-bottom: 6px; flex-shrink: 0; width: 100%; }
  h1 { 
    color: #ff0000; font-size: clamp(1.2rem, 5.5vw, 2rem); white-space: normal; font-weight: 900; 
    font-style: italic; text-align: center; text-transform: uppercase; letter-spacing: 0.02em; line-height: 1.1; width: 100%; margin-bottom: 4px;
    text-shadow: 2px 2px 0px #000, -2px -2px 0px #000, 2px -2px 0px #000, -2px 2px 0px #000;
  }
  
  .controls-row { display: flex; gap: 4px; width: 100%; justify-content: space-between; flex-wrap: nowrap; }
  .mode-btn { 
    background: #fff; border: 2px solid #000; font-size: 0.65rem; font-weight: 800; padding: 6px 2px; 
    cursor: pointer; border-radius: 4px; text-transform: uppercase; flex: 1; text-align: center; 
    white-space: nowrap; transition: all 0.1s; color: #000;
  }
  .mode-btn.active { background: #000; color: #fff; }
  
  #btnPause { background: #00aa00; color: #fff; border-color: #00aa00; }
  #btnPassThrough { background: #fff; color: #000; border-color: #000; }

  button.ctrl-btn {
    background: #ffffff; border: 1px solid #000000; color: #000000; padding: 4px 8px; border-radius: 4px; 
    font-size: 0.7rem; font-weight: 700; cursor: pointer; text-transform: uppercase;
  }
  button.ctrl-btn:active { background: #000000; color: #ffffff; }

  .iv-tabs { display: flex; gap: 2px; margin-bottom: 6px; flex-shrink: 0; flex-wrap: wrap;}
  .iv-tab { 
    flex: 1 1 10%; padding: 6px 0; text-align: center; font-size: 0.65rem; 
    background: #ffffff; border: 1px solid #000; cursor: pointer; border-radius: 4px; font-weight: 800;
  }
  .iv-tab.on { background: #000000; color: #ffffff; }

  .roll-wrapper {
    display: flex; align-items: center; gap: 4px; background: #f4f4f4; border: 1px solid #000; 
    border-radius: 4px; padding: 4px; margin-bottom: 6px; flex-shrink: 0;
  }
  .roll-nav {
    background: #e0e0e0; border: 1px solid #000; border-radius: 3px; width: 32px; height: 48px; 
    font-size: 1.2rem; font-weight: bold; display: flex; align-items: center; justify-content: center; cursor: pointer;
  }
  .roll-nav:active { background: #000; color: #fff; }
  .piano-roll { display: flex; flex: 1; justify-content: space-between; }
  .pk {
    flex: 1; height: 64px; background: #ffffff; border: 1px solid #000000; border-radius: 0 0 3px 3px; margin: 0 1px; 
    display: flex; flex-direction: column; justify-content: flex-end; align-items: center; font-size: 0.75rem; 
    font-weight: 700; padding-bottom: 6px; cursor: pointer; color: #000000; transition: all 0.1s;
  }
  .pk.sh { background: #000000; color: #ffffff; height: 42px; }
  .pk.on { border: 3px solid #ff0000 !important; z-index: 2; position: relative; }
  .pk.on-top { border: 3px solid #0066ff !important; z-index: 2; position: relative; }
  .pk.disabled { cursor: not-allowed; opacity: 0.3; background: #ccc !important; color: #888 !important; }

  .param-strip {
    display: flex; align-items: center; justify-content: space-between; border: 2px solid #000; 
    border-radius: 4px; padding: 6px 10px; margin-bottom: 6px; background: #fafafa; flex-shrink: 0;
  }
  .param-side { display: flex; flex-direction: column; gap: 2px; }
  .param-lbl { font-size: 0.65rem; color: #555; text-transform: uppercase; font-weight: 800; }

  .dual-readout { display: flex; margin-bottom: 6px; flex-shrink: 0; width: 100%; }
  .readout-box {
    flex: 1; border: 3px solid #000; border-radius: 6px; padding: 6px 6px; 
    text-align: center; background: #f0f0f0; position: relative;
  }
  .val-large { font-size: 2.8rem; font-weight: 900; line-height: 1.1; letter-spacing: -0.02em; }
  .val-lbl { font-size: 0.85rem; text-transform: uppercase; font-weight: 900; color: #000; margin-top: 2px; }
  #signalLight {
    position: absolute; top: 10px; left: 10px; width: 12px; height: 12px;
    border-radius: 50%; background: #e0e0e0; border: 2px solid #000; transition: background 0.05s, box-shadow 0.05s;
  }
  #captureStateLbl { position: absolute; top: 10px; right: 10px; font-size: 0.7rem; font-weight: 900; color: #666; text-transform: uppercase; }
  .textbook-bps { position: absolute; bottom: 6px; right: 8px; font-size: 0.85rem; font-weight: 900; color: #666; }

  .workspace { flex: 1 1 auto; overflow-y: auto; border: 1px solid #000; border-radius: 4px 4px 0 0; border-bottom: none; background: #ffffff; display: flex; flex-direction: column; }
  
  table { width: 100%; border-collapse: collapse; text-align: center; font-size: 0.75rem; table-layout: fixed; }
  th:nth-child(1) { width: 15%; } th:nth-child(2) { width: 16%; } th:nth-child(3) { width: 22%; } th:nth-child(4) { width: 17%; } th:nth-child(5) { width: 20%; } th:nth-child(6) { width: 10%; }
  th { position: sticky; top: 0; background: #ffffff; border-bottom: 2px solid #000; padding: 4px 2px; font-weight: 700; text-transform: uppercase; z-index: 2; }
  td { padding: 4px 2px; border-bottom: 1px solid #e0e0e0; }
  .w { color: #555; font-weight: 600; }
  .btn-del { background: transparent; border: 1px solid #d00000; color: #d00000; border-radius: 4px; font-weight: bold; cursor: pointer; padding: 2px 6px; font-size: 0.7rem; }
  .btn-del:active { background: #d00000; color: #fff; }

  #analysisBox { background: #fff8f8; border: 1px solid #000; border-top: 2px solid #000; padding: 6px 8px; flex-shrink: 0; margin-bottom: 4px; }

  /* Guide Styles */
  .guide-tabs { display: flex; border-bottom: 2px solid #000; background: #f0f0f0; flex-shrink: 0; }
  .gt-btn { flex: 1; padding: 8px 4px; font-size: 0.7rem; font-weight: 900; border: none; border-right: 1px solid #ccc; background: transparent; cursor: pointer; color: #555; text-transform: uppercase; }
  .gt-btn:last-child { border-right: none; }
  .gt-btn.active { background: #fff; color: #d00000; border-bottom: 2px solid #fff; margin-bottom: -2px; }

  .guide-pane { display: none; padding: 8px; flex-direction: column; gap: 8px; background: #f9f9f9; overflow-y: auto; flex: 1; }
  .guide-pane.active { display: flex; }

  .guide-step { border: 2px solid #000; border-radius: 6px; padding: 8px; background: #fff; }
  .guide-step h3 { font-size: 0.85rem; color: #000; margin-bottom: 4px; text-transform: uppercase; font-weight: 900; background: #eee; padding: 4px; border-radius: 2px; }
  .guide-step p { font-size: 0.75rem; margin-bottom: 6px; font-weight: 600; color: #444; line-height: 1.2; }
  
  .action-row { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 6px; justify-content: center; }
  .action-btn { background: #e0f0ff; border: 1px solid #0066ff; color: #0044bb; font-size: 0.75rem; font-weight: 800; padding: 4px 8px; border-radius: 4px; cursor: pointer; box-shadow: 0 2px 0 #0066ff; transition: transform 0.05s, box-shadow 0.05s; display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 60px;}
  .action-btn:active { transform: translateY(2px); box-shadow: 0 0 0 #0066ff; }
  
  /* Logged State for Buttons */
  .action-btn.logged { background: #e6ffe6; border-color: #00aa00; color: #006600; box-shadow: 0 2px 0 #00aa00; }
  .action-btn.logged:active { box-shadow: 0 0 0 #00aa00; }

  .guide-result { font-size: 0.75rem; font-weight: 600; padding: 6px; background: #fff; border: 1px dashed #000; text-align: center; line-height: 1.4; border-radius: 4px; }
  .guide-res-wait { background: #f4f4f4; color: #666; border: 1px dashed #999; font-style: italic; }
  .guide-res-pass { background: #e6ffe6; color: #006600; border: 2px solid #00aa00; font-weight: 900; }
  .guide-res-warn { background: #ffe6e6; color: #d00000; border: 2px solid #d00000; font-weight: 900; }

  .dynamic-controls { display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 8px; background: #eee; padding: 8px; border-radius: 4px; border: 1px solid #ccc; }
  .dynamic-btn { font-size: 1.2rem; font-weight: 900; width: 36px; height: 36px; border-radius: 50%; border: 2px solid #000; background: #fff; cursor: pointer; display:flex; justify-content:center; align-items:center; transition: opacity 0.2s;}
  .dynamic-btn:active:not(:disabled) { background: #000; color: #fff; }
  .dynamic-btn:disabled { cursor: not-allowed; opacity: 0.3; }
  .dynamic-target { font-size: 1.2rem; font-weight: 900; color: #d00000; min-width: 40px; text-align: center; }

  .big-nav-controls { display: flex; gap: 12px; padding-top: 2px; flex-shrink: 0; margin-bottom: 0; }
  .big-nav-controls button {
    flex: 1; height: 42px; font-size: 1.2rem; font-weight: 900; border-radius: 8px; border: 3px solid #000; 
    background: #f4f4f4; color: #000; cursor: pointer; box-shadow: 0 4px 0 #000;
  }
  .big-nav-controls button:active { transform: translateY(2px); box-shadow: 0 2px 0 #000; background: #e0e0e0; }
  
  .laptop-hint { text-align: center; font-size: 0.55rem; color: #888; margin-top: 8px; margin-bottom: 4px; text-transform: uppercase; font-weight: 800; letter-spacing: 0.05em; flex-shrink: 0; }
</style>
</head>
<body>

<div id="startOverlay">
  <h1>DAN'S BEAT SPEED DETECTOR</h1>
  <button id="bigStartBtn">ENTER</button>
</div>

<div class="header">
  <h1>DAN'S BEAT SPEED DETECTOR</h1>
  <div class="controls-row">
    <button class="mode-btn active" id="btnModeDet" onclick="switchMainMode('DET')">LOGS</button>
    <button class="mode-btn" id="btnModeGuide" onclick="switchMainMode('GUIDE')">GUIDE</button>
    <button class="mode-btn active" id="btnPause">MIC: ON</button>
    <button class="mode-btn" id="btnPassThrough">PASS: OFF</button>
  </div>
</div>

<div class="iv-tabs" id="ivTabs">
  <button class="iv-tab on" data-iv="M3">M3</button>
  <button class="iv-tab" data-iv="M6">M6</button>
  <button class="iv-tab" data-iv="P4">P4</button>
  <button class="iv-tab" data-iv="P5">P5</button>
  <button class="iv-tab" data-iv="P8">P8</button>
  <button class="iv-tab" data-iv="M10">M10</button>
  <button class="iv-tab" data-iv="P12">P12</button>
  <button class="iv-tab" data-iv="P15">P15</button>
  <button class="iv-tab" data-iv="M17">M17</button>
</div>

<div class="roll-wrapper">
  <button class="roll-nav" id="octDown">‹</button>
  <div class="piano-roll" id="pianoRoll"></div>
  <button class="roll-nav" id="octUp">›</button>
</div>

<div class="param-strip">
  <div class="param-side" style="text-align: left;">
    <span class="param-lbl">Interval</span>
    <b id="lblInterval" style="font-size: 1.1rem; font-weight: 900;">—</b>
  </div>
  <div class="param-side" style="text-align: right;">
    <span class="param-lbl">Coincident Partial</span>
    <b id="coincidentPartial" style="font-size: 0.95rem; font-weight: 800;">—</b>
  </div>
</div>

<div class="dual-readout">
  <div class="readout-box">
    <div id="signalLight"></div>
    <div id="captureStateLbl">IDLE</div>
    <div class="val-large" id="avgVal">—</div>
    <div class="val-lbl">AVERAGE BPS</div>
    <div class="textbook-bps" id="lblTarget">~—</div>
  </div>
</div>

<div class="workspace">
  <div id="logContainer">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; padding: 4px 8px;">
      <span style="font-size: 0.8rem; font-weight: bold; text-transform: uppercase; color: #333;">Progression Log</span>
      <button class="ctrl-btn" id="clearBtn">Clear All Data</button>
    </div>
    <table>
      <thead><tr><th>Int.</th><th>Note</th><th>Measured</th><th>% Δ</th><th>Ref</th><th></th></tr></thead>
      <tbody id="logBody"><tr><td colspan="6" style="text-align:center; padding:15px; color:#666;">Logs automatically upon solid capture</td></tr></tbody>
    </table>
    <div id="analysisBox" style="display: none;"></div>
  </div>

  <div id="guideContainer" style="display: none; height: 100%; flex-direction: column;">
    <div class="guide-tabs">
      <button class="gt-btn active" onclick="switchGuideTab('TEMP')">TEMP</button>
      <button class="gt-btn" onclick="switchGuideTab('UP')">UP</button>
      <button class="gt-btn" onclick="switchGuideTab('DOWN')">DOWN</button>
      <button class="gt-btn" onclick="switchGuideTab('CHECK')">CHECKS</button>
    </div>

    <div class="guide-pane active" id="gPane-TEMP">
      <div class="guide-step">
        <h3>1. Tune A4 (Concert Pitch)</h3>
        <button class="ctrl-btn" id="btnTunerToggle" style="width:100%; margin-bottom:4px; font-size:0.8rem;">TUNER: OFF</button>
        <div class="guide-result guide-res-wait" id="tunerReadout" style="min-height: 38px; display:flex; align-items:center; justify-content:center; flex-direction:column;">--- Hz</div>
      </div>
      <div class="guide-step">
        <h3>2. Prove A3 from A4</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="53" data-iv="M3" data-label="F3 (M3)" onclick="setTarget(53, 'M3')">F3 (M3)</button>
          <button class="action-btn" data-midi="53" data-iv="M10" data-label="F3 (M10)" onclick="setTarget(53, 'M10')">F3 (M10)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes2">Awaiting logs...</div>
      </div>
      <div class="guide-step">
        <h3>3. Set F3 Anchor</h3>
        <p>Aim for ~6.93 bps.</p>
        <div class="action-row"><button class="action-btn" data-midi="53" data-iv="M3" data-label="F3 (M3)" onclick="setTarget(53, 'M3')">F3 (M3)</button></div>
        <div class="guide-result guide-res-wait" id="guideRes3">Awaiting logs...</div>
      </div>
      <div class="guide-step">
        <h3>4. Prove F3-F4 Octave</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="49" data-iv="M3" data-label="C#3 (M3)" onclick="setTarget(49, 'M3')">C#3 (M3)</button>
          <button class="action-btn" data-midi="49" data-iv="M10" data-label="C#3 (M10)" onclick="setTarget(49, 'M10')">C#3 (M10)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes4">Awaiting logs...</div>
      </div>
      <div class="guide-step">
        <h3>5. The 'F' Skeleton (Contiguous 3rds)</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="53" data-iv="M3" data-label="F3 (M3)" onclick="setTarget(53, 'M3')">F3 (M3)</button>
          <button class="action-btn" data-midi="57" data-iv="M3" data-label="A3 (M3)" onclick="setTarget(57, 'M3')">A3 (M3)</button>
          <button class="action-btn" data-midi="61" data-iv="M3" data-label="C#4 (M3)" onclick="setTarget(61, 'M3')">C#4 (M3)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes5">Awaiting logs...</div>
      </div>
      <div class="guide-step">
        <h3>6. The 'F#' Skeleton</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="54" data-iv="P5" data-label="F#3 (P5)" onclick="setTarget(54, 'P5')">F#3 (P5)</button>
          <button class="action-btn" data-midi="53" data-iv="P4" data-label="F3 (P4)" onclick="setTarget(53, 'P4')">F3 (P4)</button>
          <button class="action-btn" data-midi="57" data-iv="P4" data-label="A3 (P4)" onclick="setTarget(57, 'P4')">A3 (P4)</button>
          <button class="action-btn" data-midi="54" data-iv="M3" data-label="F#3 (M3)" onclick="setTarget(54, 'M3')">F#3 (M3)</button>
          <button class="action-btn" data-midi="58" data-iv="M3" data-label="A#3 (M3)" onclick="setTarget(58, 'M3')">A#3 (M3)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes6">Awaiting M3 and P4/P5 checks...</div>
      </div>
      <div class="guide-step">
        <h3>7. The 'G' Skeleton</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="55" data-iv="P5" data-label="G3 (P5)" onclick="setTarget(55, 'P5')">G3 (P5)</button>
          <button class="action-btn" data-midi="54" data-iv="P4" data-label="F#3 (P4)" onclick="setTarget(54, 'P4')">F#3 (P4)</button>
          <button class="action-btn" data-midi="58" data-iv="P4" data-label="A#3 (P4)" onclick="setTarget(58, 'P4')">A#3 (P4)</button>
          <button class="action-btn" data-midi="55" data-iv="M3" data-label="G3 (M3)" onclick="setTarget(55, 'M3')">G3 (M3)</button>
          <button class="action-btn" data-midi="59" data-iv="M3" data-label="B3 (M3)" onclick="setTarget(59, 'M3')">B3 (M3)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes7">Awaiting M3 and P4/P5 checks...</div>
      </div>
      <div class="guide-step">
        <h3>8. The 'G#' Skeleton</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="56" data-iv="P5" data-label="G#3 (P5)" onclick="setTarget(56, 'P5')">G#3 (P5)</button>
          <button class="action-btn" data-midi="55" data-iv="P4" data-label="G3 (P4)" onclick="setTarget(55, 'P4')">G3 (P4)</button>
          <button class="action-btn" data-midi="59" data-iv="P4" data-label="B3 (P4)" onclick="setTarget(59, 'P4')">B3 (P4)</button>
          <button class="action-btn" data-midi="56" data-iv="M3" data-label="G#3 (M3)" onclick="setTarget(56, 'M3')">G#3 (M3)</button>
          <button class="action-btn" data-midi="60" data-iv="M3" data-label="C4 (M3)" onclick="setTarget(60, 'M3')">C4 (M3)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes8">Awaiting M3 and P4/P5 checks...</div>
      </div>
      <div class="guide-step">
        <h3>9. Inside 4ths & 5ths Verification</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="53" data-iv="P5" data-label="F3 (P5)" onclick="setTarget(53, 'P5')">F3 (P5)</button>
          <button class="action-btn" data-midi="60" data-iv="P4" data-label="C4 (P4)" onclick="setTarget(60, 'P4')">C4 (P4)</button>
          <button class="action-btn" data-midi="54" data-iv="P5" data-label="F#3 (P5)" onclick="setTarget(54, 'P5')">F#3 (P5)</button>
          <button class="action-btn" data-midi="61" data-iv="P4" data-label="C#4 (P4)" onclick="setTarget(61, 'P4')">C#4 (P4)</button>
        </div>
        <div class="guide-result guide-res-wait" id="guideRes9">Awaiting logs...</div>
      </div>
      <div class="guide-step">
        <h3>10. Chromatic M3 Sweep</h3>
        <div class="action-row">
          <button class="action-btn" data-midi="53" data-iv="M3" data-label="F3" onclick="setTarget(53, 'M3')">F3</button>
          <button class="action-btn" data-midi="54" data-iv="M3" data-label="F#3" onclick="setTarget(54, 'M3')">F#3</button>
          <button class="action-btn" data-midi="55" data-iv="M3" data-label="G3" onclick="setTarget(55, 'M3')">G3</button>
          <button class="action-btn" data-midi="56" data-iv="M3" data-label="G#3" onclick="setTarget(56, 'M3')">G#3</button>
          <button class="action-btn" data-midi="57" data-iv="M3" data-label="A3" onclick="setTarget(57, 'M3')">A3</button>
          <button class="action-btn" data-midi="58" data-iv="M3" data-label="A#3" onclick="setTarget(58, 'M3')">A#3</button>
          <button class="action-btn" data-midi="59" data-iv="M3" data-label="B3" onclick="setTarget(59, 'M3')">B3</button>
          <button class="action-btn" data-midi="60" data-iv="M3" data-label="C4" onclick="setTarget(60, 'M3')">C4</button>
          <button class="action-btn" data-midi="61" data-iv="M3" data-label="C#4" onclick="setTarget(61, 'M3')">C#4</button>
        </div>
