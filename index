function getPitchYin(buf, sampleRate) {
  let threshold = 0.15; let SIZE = buf.length; let halfSize = Math.floor(SIZE / 2);
  let yinBuffer = new Float32Array(halfSize); yinBuffer[0] = 1; let runningSum = 0; let foundTau = -1;
  for (let tau = 1; tau < halfSize; tau++) { for (let i = 0; i < halfSize; i++) { let delta = buf[i] - buf[i + tau]; yinBuffer[tau] += delta * delta; } }
  for (let tau = 1; tau < halfSize; tau++) { runningSum += yinBuffer[tau]; yinBuffer[tau] *= tau / runningSum; }
  for (let tau = 2; tau < halfSize; tau++) { if (yinBuffer[tau] < threshold) { while (tau + 1 < halfSize && yinBuffer[tau + 1] < yinBuffer[tau]) { tau++; } foundTau = tau; break; } }
  if (foundTau === -1) { let minVal = Infinity; for (let tau = 2; tau < halfSize; tau++) { if (yinBuffer[tau] < minVal) { minVal = yinBuffer[tau]; foundTau = tau; } } }
  let s0 = yinBuffer[foundTau - 1]; let s1 = yinBuffer[foundTau]; let s2 = yinBuffer[foundTau + 1]; let shift = 0;
  if (s0 !== undefined && s2 !== undefined) { let denom = 2 * (s0 - 2*s1 + s2); if (denom !== 0) shift = (s0 - s2) / denom; }
  return sampleRate / (foundTau + shift);
}

function runTuner() {
  if(!tunerActive || !isRunning || micPaused) return;
  analyserTuner.getFloatTimeDomainData(tunerDataArray);
  let rawPitch = getPitchYin(tunerDataArray, audioCtx.sampleRate);
  
  if(rawPitch > 420 && rawPitch < 460) { 
    if (smoothedPitch === -1) smoothedPitch = rawPitch;
    else smoothedPitch = (smoothedPitch * 0.92) + (rawPitch * 0.08);

    let cents = 1200 * Math.log2(smoothedPitch / 440.0);
    let color = Math.abs(cents) < 1.5 ? '#00aa00' : '#d00000';
    let sign = cents > 0 ? '+' : ''; let text = `${sign}${cents.toFixed(1)}c`;
    
    $('tunerReadout').innerHTML = `<span style="font-size:1.4rem; font-weight:900; line-height:1.2;">${smoothedPitch.toFixed(1)} Hz</span><br><span style="color:${color}; font-weight:900; font-size:0.9rem;">${text}</span>`;
  } else { smoothedPitch = -1; }
  if(tunerActive) requestAnimationFrame(runTuner);
}

$('bigStartBtn').addEventListener('click', async () => {
  $('startOverlay').style.display = 'none';
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: false, channelCount: 1 } });
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') await audioCtx.resume();
    const src = audioCtx.createMediaStreamSource(stream);
    analyserFull = audioCtx.createAnalyser(); analyserFull.fftSize = 4096; analyserFull.smoothingTimeConstant = 0.7;
    
    tunerFilter = audioCtx.createBiquadFilter(); tunerFilter.type = 'bandpass'; tunerFilter.frequency.value = 440.0; tunerFilter.Q.value = 8.0; 
    analyserTuner = audioCtx.createAnalyser(); analyserTuner.fftSize = 4096;
    src.connect(tunerFilter); tunerFilter.connect(analyserTuner);

    const cfg = getConfig(lowerMidi, curIv); filters = buildFilters(cfg);
    gainNode = audioCtx.createGain(); gainNode.gain.value = 250.0; 
    monitorGain = audioCtx.createGain(); monitorGain.gain.value = monitorOn && !micPaused ? 25.0 : 0.0;
    const scriptNode = audioCtx.createScriptProcessor(1024, 1, 1);

    src.connect(analyserFull); src.connect(filters[0]); filters[0].connect(filters[1]); filters[1].connect(filters[2]); 
    filters[2].connect(gainNode); filters[2].connect(monitorGain); monitorGain.connect(audioCtx.destination);
    gainNode.connect(scriptNode); scriptNode.connect(audioCtx.destination);

    scriptNode.onaudioprocess = (e) => {
      if (!isRunning || micPaused) return; 
      const inputData = e.inputBuffer.getChannelData(0);
      for (let offset = 0; offset < inputData.length; offset += currentChunkSize) {
          let sum = 0, limit = Math.min(currentChunkSize, inputData.length - offset);
          for (let i = 0; i < limit; i++) sum += inputData[offset + i] * inputData[offset + i];
          const rms = Math.sqrt(sum / limit); envelopeRunning = rms;
          const strikeMult = currentChunkSize === 256 ? 1.8 : 2.5;
          const isStrike = (envelopeRunning > lastEnvelope * strikeMult) && (envelopeRunning > 0.005);
          lastEnvelope = envelopeRunning;
          noiseFloor = noiseFloor * 0.996 + Math.min(envelopeRunning, noiseFloor * 1.5) * 0.004;
          if (noiseFloor < 0.000001) noiseFloor = 0.000001;
          const snr = envelopeRunning / noiseFloor;
          
          if (isStrike && snr > 3.0) {
            const timeNow = performance.now();
            if (timeNow - lastAttackTime > 400 && (captureState === 'IDLE' || captureState === 'LOCKED')) { 
              envHistory = []; lastAttackTime = timeNow; transientSamplesLeft = currentChunkSize === 256 ? 72 : 18; 
              captureState = 'WAIT'; captureStartTime = timeNow; capturedBeats = [];
              $('captureStateLbl').textContent = 'WAITING...'; $('captureStateLbl').style.color = '#ff9900';
            }
          }
          if (transientSamplesLeft > 0) { transientSamplesLeft--; } 
          else { envHistory.push({ val: envelopeRunning }); const fps = audioCtx.sampleRate / currentChunkSize; if (envHistory.length > Math.round(3.5 * fps)) envHistory.shift(); }
      }
    };
    isRunning = true; lastEnvelope = 0; rafId = requestAnimationFrame(renderLoop);
  } catch(e) { alert('Microphone setup failed:\n' + e.message); $('startOverlay').style.display = 'flex'; }
});

function buildFilters(cfg) {
  const Q = (cfg.center / (cfg.bpHi - cfg.bpLo)) * 1.4;
  const f1 = audioCtx.createBiquadFilter(); f1.type = 'bandpass'; f1.frequency.value = cfg.center; f1.Q.value = Q;
  const f2 = audioCtx.createBiquadFilter(); f2.type = 'bandpass'; f2.frequency.value = cfg.center; f2.Q.value = Q;
  const f3 = audioCtx.createBiquadFilter(); f3.type = 'bandpass'; f3.frequency.value = cfg.center; f3.Q.value = Q;
  return [f1, f2, f3];
}
function retuneFilters(cfg) {
  if (!audioCtx || filters.length === 0) return;
  const Q = (cfg.center / (cfg.bpHi - cfg.bpLo)) * 1.4;
  filters[0].frequency.value = cfg.center; filters[0].Q.value = Q; filters[1].frequency.value = cfg.center; filters[1].Q.value = Q; filters[2].frequency.value = cfg.center; filters[2].Q.value = Q;
}

function renderLoop(ts) {
  if (!isRunning) return; rafId = requestAnimationFrame(renderLoop); if (micPaused) return;
  const cfg = getConfig(lowerMidi, curIv); const snr = envelopeRunning / noiseFloor; const threshold = getDynamicThresholds(lowerMidi, curIv);
  if (snr > threshold.snr && envelopeRunning > threshold.env) { sigLight.style.background = '#00ff00'; } else { sigLight.style.background = '#e0e0e0'; }
  let now = performance.now(); const fps = audioCtx.sampleRate / currentChunkSize; const minHistFrames = Math.round(fps * 0.4);
  
  if (captureState === 'WAIT' && now - captureStartTime > 800) { captureState = 'CAPTURING'; $('captureStateLbl').textContent = 'RECORDING...'; $('captureStateLbl').style.color = '#d00000'; }
  if (captureState === 'CAPTURING') {
      if (envHistory.length >= minHistFrames && snr > threshold.snr && envelopeRunning > threshold.env) { let beat = detectBeat(envHistory, cfg.theoBeat, curIv); if (beat !== null) capturedBeats.push(beat); }
      if (now - captureStartTime > 3300 || snr < threshold.snr * 0.8) {
          if (capturedBeats.length > 5) {
              capturedBeats.sort((a,b) => a-b); let median = capturedBeats[Math.floor(capturedBeats.length/2)];
              let stableCount = capturedBeats.filter(b => Math.abs(b - median) < 0.6).length;
              if (stableCount / capturedBeats.length >= 0.7) {
                  lockedAverage = median; avgEl.textContent = lockedAverage.toFixed(2);
                  $('captureStateLbl').textContent = 'LOCKED!'; $('captureStateLbl').style.color = '#00aa00'; captureState = 'LOCKED'; finalizeLog(); 
              } else { captureState = 'IDLE'; $('captureStateLbl').textContent = 'UNSTABLE'; $('captureStateLbl').style.color = '#d00000'; setTimeout(() => { if(!micPaused && captureState==='IDLE') resetCapture(); }, 1500); }
          } else { captureState = 'IDLE'; $('captureStateLbl').textContent = 'NO BEAT'; $('captureStateLbl').style.color = '#d00000'; setTimeout(() => { if(!micPaused && captureState==='IDLE') resetCapture(); }, 1500); }
      }
  }
}

function detectBeat(history, theoreticalBeat, ivKey) {
  const N = history.length; const fps = audioCtx.sampleRate / currentChunkSize; const vals = history.map(h => h.val); const windowSize = Math.round(fps * 0.45);
  const AC = new Float32Array(N);
  for (let i = 0; i < N; i++) { let start = Math.max(0, i - Math.floor(windowSize / 2)), end = Math.min(N, i + Math.ceil(windowSize / 2)), localSum = 0; for (let j = start; j < end; j++) localSum += vals[j]; AC[i] = vals[i] - (localSum / (end - start)); }
  const minLag = Math.max(2, Math.round(fps / 55)), maxLag = Math.min(N - 2, Math.round(fps / 0.5)); let ac0 = 0; for (let i = 0; i < N; i++) ac0 += AC[i] * AC[i]; if (ac0 < 1e-12) return null;
  const ac = new Float32Array(maxLag + 1); for (let lag = minLag; lag <= maxLag; lag++) { let sum = 0; for (let i = 0; i < N - lag; i++) sum += AC[i] * AC[i + lag]; ac[lag] = sum / ac0; }
  const peaks = []; let acThreshold = theoreticalBeat > 10.0 ? 0.015 : 0.03; if (ivKey === 'P4' || ivKey === 'P5') acThreshold = 0.01; 
  for (let lag = minLag + 1; lag < maxLag; lag++) { if (ac[lag] > ac[lag - 1] && ac[lag] > ac[lag + 1] && ac[lag] > acThreshold) peaks.push({ lag, ac: ac[lag] }); }
  if (peaks.length === 0) return null; let bestCandidate = null, maxScore = -1;
  peaks.forEach(p => {
    let alpha = ac[p.lag - 1], beta = ac[p.lag], gamma = ac[p.lag + 1]; let denom = alpha - 2 * beta + gamma; let pLag = p.lag;
    if (Math.abs(denom) > 1e-5) pLag = p.lag + 0.5 * (alpha - gamma) / denom; let rate = fps / pLag; let allowedDev = Math.max(1.0, theoreticalBeat * 0.35); 
    if (Math.abs(rate - theoreticalBeat) > allowedDev) return; 
    let ratio = rate / theoreticalBeat; let distanceDev = Math.abs(Math.log2(ratio)); let proximityWeight = Math.exp(-0.5 * Math.pow(distanceDev / 0.8, 2));
    if (rate < 0.3 || rate > 35.0) proximityWeight = 0.0; let score = p.ac * proximityWeight; if (score > maxScore) { maxScore = score; bestCandidate = rate; }
  }); return maxScore > 0.005 ? bestCandidate : null;
}

