<script>
const NOTES = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
const IS_SHARP = new Set([1,3,6,8,10]);
const freq = m => 440 * Math.pow(2, (m - 69) / 12);
const noteName = m => NOTES[m % 12] + (Math.floor(m / 12) - 1);

const IV = {
  M3:  { sem:4,  lp:5, up:4, name:'Major Third' }, 
  M6:  { sem:9,  lp:5, up:3, name:'Major Sixth' }, 
  P4:  { sem:5,  lp:4, up:3, name:'Perf. Fourth' }, 
  P5:  { sem:7,  lp:3, up:2, name:'Perf. Fifth' }, 
  P8:  { sem:12, lp:2, up:1, name:'Octave' },
  M10: { sem:16, lp:5, up:2, name:'Major Tenth' }, 
  P12: { sem:19, lp:3, up:1, name:'Perf. Twelfth' },
  P15: { sem:24, lp:4, up:1, name:'Double Octave' },
  M17: { sem:28, lp:5, up:1, name:'Major 17th' }, 
};

// BUG FIX: Accurate calculation of valid intervals allowing P8, P12, P15 and proper limits
Object.keys(IV).forEach(key => {
  let min = 108, max = 21;
  for (let m = 21; m <= 108; m++) {
    if (m + IV[key].sem > 108) continue;
    let fLo = freq(m), fHi = freq(m + IV[key].sem);
    let beat = Math.abs(IV[key].up * fHi - IV[key].lp * fLo);
    let isPerfect = ['P8', 'P12', 'P15'].includes(key);
    
    // Limits interval ranges accurately between 0.15 BPS and 25 BPS, ignoring perfect intervals
    if (isPerfect || (beat >= 0.15 && beat <= 25.0)) { 
      if (m < min) min = m; 
      if (m > max) max = m; 
    }
  }
  IV[key].min = min; IV[key].max = max;
});

function getConfig(lowerMidi, ivKey) {
  const iv = IV[ivKey]; const upperMidi = lowerMidi + iv.sem;
  const fLo = freq(lowerMidi), fHi = freq(upperMidi);
  const pLo = iv.lp * fLo, pHi = iv.up * fHi;
  const center = (pLo + pHi) / 2; const theoBeat = Math.abs(iv.up * fHi - iv.lp * fLo);
  let margin = Math.max(22, theoBeat * 1.2 + 8);
  if (ivKey === 'M10' || ivKey === 'M17') margin *= 1.8; 
  if (lowerMidi < 40) margin *= 1.4; 
  return { lowerMidi, upperMidi, fLo, fHi, pLo, pHi, center, theoBeat, bpLo: center - margin, bpHi: center + margin, iv, ivKey };
}

function getDynamicThresholds(midiNote, ivKey) {
  let minEnv = 0.003, minSnr = 2.5;   
  if (midiNote > 60) {
    let boostFactor = Math.min(1, (midiNote - 60) / 36); 
    minEnv = 0.003 - (boostFactor * 0.0025); minSnr = 2.5 - (boostFactor * 1.5);      
  }
  if (ivKey === 'P4' || ivKey === 'P5') { minSnr *= 0.75; minEnv *= 0.8; }
  minEnv *= 0.15; minSnr *= 0.5;  
  return { env: Math.max(0.0001, minEnv), snr: Math.max(1.0, minSnr) };
}

let curIv = 'M3', lowerMidi = 53, rollBaseMidi = 53; 
let audioCtx = null, analyserFull = null, analyserTuner = null, filters = [], tunerFilter = null, gainNode = null, monitorGain = null;
let isRunning = false, micPaused = false, monitorOn = false, rafId = null, currentChunkSize = 1024; 
let noiseFloor = 0.001, envelopeRunning = 0, lastEnvelope = 0, envHistory = [];    
let transientSamplesLeft = 0, lastAttackTime = 0;
let loggedIntervals = { M3: [], M6: [], P4: [], P5: [], P8: [], M10: [], P12: [], P15: [], M17: [] };
let captureState = 'IDLE', captureStartTime = 0, capturedBeats = [], lockedAverage = null;
let tunerActive = false, tunerDataArray = null, smoothedPitch = -1;

// Dynamic Expansion State
let expUpMidi = 66; // F#4 (First note above temperament)
let expDownMidi = 52; // E3 (First note below temperament)

// Dynamic Sweep State
let sweepMidi = 41; // F2
let sweepIvType = 'M3';

const $ = id => document.getElementById(id);
const avgEl = $('avgVal'), sigLight = $('signalLight');

function loadPersistence() {
  const savedLogs = localStorage.getItem('danDetectorLogs');
  if(savedLogs) {
    try { loggedIntervals = JSON.parse(savedLogs); renderLogTable(); analyzeTemperament(); updateGuide(); } catch(e) {}
  }
}
function savePersistence() { localStorage.setItem('danDetectorLogs', JSON.stringify(loggedIntervals)); }
loadPersistence();

// UI Toggles
function switchMainMode(mode) {
  if (mode === 'DET') {
    $('btnModeDet').classList.add('active'); $('btnModeGuide').classList.remove('active');
    $('logContainer').style.display = 'block'; $('guideContainer').style.display = 'none';
  } else {
    $('btnModeGuide').classList.add('active'); $('btnModeDet').classList.remove('active');
    $('logContainer').style.display = 'none'; $('guideContainer').style.display = 'flex';
    updateGuide(); renderDynExpanders(); renderSweep();
  }
}

function switchGuideTab(tab) {
  document.querySelectorAll('.gt-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.guide-pane').forEach(p => p.classList.remove('active'));
